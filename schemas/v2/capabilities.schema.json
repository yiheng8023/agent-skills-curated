{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yiheng8023/agent-skills-curated/schemas/v2/capabilities.schema.json",
  "title": "Abstract Lifecycle Capabilities",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "capabilities"],
  "properties": {
    "schema": {"const": 2},
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "stage", "description", "coverageState", "validation", "fallback"],
        "properties": {
          "id": {"type": "string", "pattern": "^capability\\.[a-z0-9][a-z0-9-]*$"},
          "stage": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1},
          "coverageState": {"type": "string", "enum": ["curated", "recipe", "runtime-resolved", "native-sufficient", "human-authority", "gap"]},
          "validation": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "fallback": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "curatedOwners": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^skill\\.curated\\.[a-z0-9][a-z0-9-]*$"}},
          "runtimeResolution": {"const": "visible-capability-inventory"}
        },
        "allOf": [
          {
            "if": {"properties": {"coverageState": {"const": "curated"}}, "required": ["coverageState"]},
            "then": {"required": ["curatedOwners"]},
            "else": {"not": {"required": ["curatedOwners"]}}
          },
          {
            "if": {"properties": {"coverageState": {"const": "runtime-resolved"}}, "required": ["coverageState"]},
            "then": {"required": ["runtimeResolution"]},
            "else": {"not": {"required": ["runtimeResolution"]}}
          }
        ]
      }
    }
  }
}
