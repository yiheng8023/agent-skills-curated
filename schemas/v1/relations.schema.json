{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yiheng8023/agent-skills-curated/schemas/v1/relations.schema.json",
  "title": "Relationship Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "relationTypes", "relations"],
  "properties": {
    "schema": {"const": 1},
    "relationTypes": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "relations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "type", "to"],
        "properties": {
          "from": {"type": "string", "minLength": 1},
          "type": {"type": "string", "minLength": 1},
          "to": {"type": "string", "minLength": 1},
          "condition": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
