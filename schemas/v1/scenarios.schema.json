{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yiheng8023/agent-skills-curated/schemas/v1/scenarios.schema.json",
  "title": "Portable Routing Scenarios",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "scenarios"],
  "properties": {
    "schema": {"const": 1},
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "family", "language", "request", "decisionClass", "expectedDecision", "expectedSkills", "excludedSkills", "requestedCapabilities", "expectedCapabilities", "humanConfirmation", "validationExpectations", "routingFacts"],
        "properties": {
          "id": {"type": "string", "pattern": "^scenario\\.[a-z0-9][a-z0-9-]*$"},
          "family": {"type": "string", "enum": ["lifecycle", "native-no-skill", "runtime-preference", "curated-workflow", "recipe-dag", "negative-near-match", "authority-ambiguity", "fallback-gap", "execution-reroute"]},
          "language": {"type": "string", "minLength": 1},
          "request": {"type": "string", "minLength": 1},
          "decisionClass": {"type": "string", "enum": ["curated", "recipe", "runtime-resolved", "native-sufficient", "human-authority", "gap"]},
          "expectedDecision": {"type": "string", "enum": ["native", "runtime", "curated", "recipe", "no-skill", "ask-user", "gap"]},
          "expectedSkills": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "excludedSkills": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "requestedCapabilities": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "expectedCapabilities": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "humanConfirmation": {"type": "boolean"},
          "validationExpectations": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "routingFacts": {
            "type": "object",
            "additionalProperties": false,
            "required": ["available", "contextSatisfied", "negativeMatch", "nativeEquivalent", "runtimeEquivalent", "risk", "cost", "permissionExpansion", "unresolvedConflict", "ambiguous"],
            "properties": {
              "available": {"type": "array", "uniqueItems": true, "items": {"type": "string", "enum": ["native", "runtime", "curated"]}},
              "contextSatisfied": {"type": "boolean"},
              "negativeMatch": {"type": "boolean"},
              "nativeEquivalent": {"type": "boolean"},
              "runtimeEquivalent": {"type": "boolean"},
              "risk": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
              "cost": {"type": "string", "enum": ["low", "meaningful"]},
              "permissionExpansion": {"type": "boolean"},
              "unresolvedConflict": {"type": "boolean"},
              "ambiguous": {"type": "boolean"}
            }
          }
        }
      }
    }
  }
}
