{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yiheng8023/agent-skills-curated/schemas/v1/capabilities.schema.json",
  "title": "Capability Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "capabilities"],
  "properties": {
    "schema": {"const": 1},
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "canonicalOwner"],
        "properties": {
          "id": {"type": "string", "pattern": "^capability\\.[a-z0-9][a-z0-9-]*$"},
          "canonicalOwner": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
