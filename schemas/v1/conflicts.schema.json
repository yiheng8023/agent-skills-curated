{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yiheng8023/agent-skills-curated/schemas/v1/conflicts.schema.json",
  "title": "Conflict Ownership Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "groups"],
  "properties": {
    "schema": {"const": 1},
    "groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "defaultOwner", "members", "resolution"],
        "properties": {
          "id": {"type": "string", "pattern": "^conflict\\.[a-z0-9][a-z0-9-]*$"},
          "defaultOwner": {"type": "string", "minLength": 1},
          "members": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "resolution": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
