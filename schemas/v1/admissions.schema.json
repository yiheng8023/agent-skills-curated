{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yiheng8023/agent-skills-curated/schemas/v1/admissions.schema.json",
  "title": "Third-Party Skill Admissions",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "admissions"],
  "properties": {
    "schema": {"const": 1},
    "admissions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["skill", "source", "thirdParty", "nativeBaselineCompared", "nativeIncrement", "overlapReviewed", "disposition", "reviewRefs", "validated"],
        "properties": {
          "skill": {"type": "string", "pattern": "^skill\\.curated\\.[a-z0-9][a-z0-9-]*$"},
          "source": {"type": "string", "minLength": 1},
          "thirdParty": {"type": "boolean"},
          "nativeBaselineCompared": {"type": "boolean"},
          "nativeIncrement": {"type": "string", "minLength": 1},
          "overlapReviewed": {"type": "boolean"},
          "disposition": {"type": "string", "enum": ["approve", "merge", "recipe-only", "adapter-only", "reject"]},
          "reviewRefs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "validated": {"type": "boolean"}
        },
        "if": {"properties": {"disposition": {"const": "approve"}}, "required": ["disposition"]},
        "then": {"properties": {"thirdParty": {"const": true}, "nativeBaselineCompared": {"const": true}, "overlapReviewed": {"const": true}, "validated": {"const": true}}}
      }
    }
  }
}
