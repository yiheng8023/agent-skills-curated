{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yiheng8023/agent-skills-curated/schemas/v1/selection.schema.json",
  "title": "Source Selection",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "source", "revision", "decisions"],
  "properties": {
    "schema": {"const": 1},
    "source": {"type": "string", "minLength": 1},
    "revision": {"type": "string", "minLength": 1},
    "decisions": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {"minLength": 1},
      "additionalProperties": {
        "enum": ["adopt", "merge", "adapter-only", "recipe-only", "reject"]
      }
    },
    "excludedExecutables": {"type": "array", "items": {"type": "string", "minLength": 1}}
  }
}
