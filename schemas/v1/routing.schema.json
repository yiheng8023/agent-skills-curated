{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yiheng8023/agent-skills-curated/schemas/v1/routing.schema.json",
  "title": "Curated Skill Routing Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "routes"],
  "properties": {
    "schema": {"const": 1},
    "routes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["skill", "aliases", "positiveTriggers", "negativeTriggers", "contextRequirements", "inputs", "outputs", "sideEffects", "validation", "riskLevel", "permissionsRequired", "fallback", "humanConfirmWhen", "languages", "agentCompatibility", "lifecycleCapabilities"],
        "properties": {
          "skill": {"type": "string", "pattern": "^skill\\.curated\\.[a-z0-9][a-z0-9-]*$"},
          "aliases": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "positiveTriggers": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "negativeTriggers": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "contextRequirements": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "inputs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "outputs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "sideEffects": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "validation": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "riskLevel": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
          "permissionsRequired": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "fallback": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "humanConfirmWhen": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "languages": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "agentCompatibility": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "lifecycleCapabilities": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
        }
      }
    }
  }
}
