{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yiheng8023/agent-skills-curated/schemas/v1/recipes.schema.json",
  "title": "Capability Recipes",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "recipes"],
  "properties": {
    "schema": {"const": 1},
    "recipes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "trigger", "steps"],
        "properties": {
          "id": {"type": "string", "pattern": "^recipe\\.[a-z0-9][a-z0-9-]*$"},
          "trigger": {"type": "string", "minLength": 1},
          "steps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["capability"],
              "properties": {
                "capability": {"type": "string", "minLength": 1},
                "when": {"type": "string", "minLength": 1}
              }
            }
          },
          "authorization": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
