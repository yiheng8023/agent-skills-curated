{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yiheng8023/agent-skills-curated/schemas/v1/sources-lock.schema.json",
  "title": "Source Lock",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "sources"],
  "properties": {
    "schema": {"const": 1},
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "provenanceStatus", "redistribution", "reviewRefs", "candidateIds", "status", "approvedForRuntime", "notes"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "kind": {"type": "string", "enum": ["git", "local"]},
          "provenanceStatus": {"type": "string", "enum": ["complete", "incomplete"]},
          "redistribution": {"type": "string", "enum": ["license-governed", "private-only"]},
          "reviewRefs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "url": {"type": "string", "minLength": 1},
          "revision": {"type": "string", "minLength": 1},
          "candidateIds": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "license": {"type": "string", "minLength": 1},
          "status": {"type": "string", "minLength": 1},
          "approvedForRuntime": {"type": "boolean"},
          "notes": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
        },
        "if": {"properties": {"kind": {"const": "local"}}, "required": ["kind"]},
        "then": {
          "properties": {
            "provenanceStatus": {"const": "incomplete"},
            "redistribution": {"const": "private-only"}
          },
          "not": {
            "anyOf": [
              {"required": ["url"]},
              {"required": ["revision"]},
              {"required": ["license"]}
            ]
          }
        }
      }
    }
  }
}
