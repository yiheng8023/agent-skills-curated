{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yiheng8023/agent-skills-curated/schemas/v1/release-manifest.schema.json",
  "title": "Release Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "skillCount", "fileCount", "files"],
  "properties": {
    "schema": {"const": 1},
    "skillCount": {"type": "integer", "minimum": 0},
    "fileCount": {"type": "integer", "minimum": 0},
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "size"],
        "properties": {
          "path": {"type": "string", "pattern": "^skills/(?:[A-Za-z0-9][A-Za-z0-9._-]*/)*[A-Za-z0-9][A-Za-z0-9._-]*$"},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "size": {"type": "integer", "minimum": 0}
        }
      }
    }
  }
}
